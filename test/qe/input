&control
calculation         = 'vc-relax',
restart_mode        = 'restart',
disk_io             = 'none'
nstep               = 500
pseudo_dir          = './'
prefix              = 'RuO'
outdir              = './temp'
etot_conv_thr       = 1.0d-6
forc_conv_thr       = 1.0d-4
verbosity           = 'high'
/

&system
ibrav               = 0,
nat                 = 6,
ntyp                = 3,
ecutwfc             = 90.D0,
ecutrho             = 360.D0,
occupations         = 'smearing',
smearing            = 'mp',
degauss             = 0.0001

!noncolin            = .true.
!lspinorb            = .true.
!nspin = 2,
!starting_magnetization(1) = 6.0, starting_magnetization(2) = -6.0,
!lacbn0 = .true.,
!acbn0_type = 2,
!lda_plus_v = .true.,
!U_projection_type = 'ortho-atomic',
!ehub_nn_distance = 0.0,
!ehub_pot_fix = .false.,
!ehub_conv_thr = 1.0D-05,
!ehub_mixing = 0.7,
!ehub_l_choice(1,3) = 1,
!ehub_l_choice(2,3) = 1,
!ehub_l_choice(3,2) = 1
/

&electrons
diagonalization     = 'david',
mixing_mode         = 'plain',
mixing_beta         = 0.3,
conv_thr            = 1.0d-9
startingwfc         = 'atomic+random'
/

